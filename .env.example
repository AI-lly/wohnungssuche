# CallMeBot configuration
# Get your API key by sending "I allow callmebot to send me messages"
# to +34 693 54 49 84 via WhatsApp.
# Keep the plus sign in your phone number (e.g. +4912345678)

CALLMEBOT_PHONE="+491735446062"
CALLMEBOT_APIKEY="7010726"

# Scraper configuration
CHECK_INTERVAL_SECONDS=300

# Search filters
# FILTER_CITIES: comma-separated city names (e.g. frankfurt,darmstadt,offenbach)
FILTER_CITIES="frankfurt"
# FILTER_ROOMS: comma-separated room counts (e.g. 2,3)
FILTER_ROOMS="2"
